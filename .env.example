# ── LLM Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGCHAIN_API_KEY=ls__...          # alias used by LangChain SDK
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=rag-observability

# ── Model Configuration ───────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_PORT=8000                  # Prometheus scrape port

# ── Quality Gate Thresholds ───────────────────────────────────────────────────
FAITHFULNESS_THRESHOLD=0.8
ANSWER_RELEVANCY_THRESHOLD=0.75
CONTEXT_RECALL_THRESHOLD=0.7
